<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>價格追蹤小幫手 V1.3</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: #f8fafc;
        }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.05); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .btn-bounce:active { transform: scale(0.95); }
        
        .sticky-search {
            position: sticky;
            top: 64px; 
            z-index: 40;
            background-color: rgba(248, 250, 252, 0.9);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .price-row-top { background-color: rgba(255, 237, 213, 0.3); }
        
        #calcDrawer {
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .drawer-hidden { transform: translateY(100%); }
        .drawer-visible { transform: translateY(0); }
    </style>
</head>
<body class="pb-24">

    <!-- 頂部導航 -->
    <header class="bg-teal-700 text-white h-16 sticky top-0 z-50 shadow-md flex items-center">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <h1 class="text-lg font-bold flex items-center">
                <i class="fas fa-tags mr-2 text-teal-300"></i> 價格追蹤
            </h1>
            <div class="flex gap-1.5">
                <button onclick="toggleCalc()" class="bg-orange-500 hover:bg-orange-600 px-3 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center">
                    <i class="fas fa-calculator mr-1"></i> 計算機
                </button>
                <!-- 恢復匯入/匯出按鈕 -->
                <div class="flex bg-white/10 rounded-lg overflow-hidden border border-white/20">
                    <button onclick="exportToExcel()" class="px-2.5 py-1.5 hover:bg-white/10 text-[10px] font-bold border-r border-white/20">匯出</button>
                    <label class="px-2.5 py-1.5 hover:bg-white/10 text-[10px] font-bold cursor-pointer">
                        匯入
                        <input type="file" class="hidden" accept=".xlsx, .xls" onchange="importFromExcel(event)">
                    </label>
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto max-w-2xl">
        <!-- 搜尋與快速新增 -->
        <div class="sticky-search px-4 py-4">
            <div class="flex items-center gap-2 bg-white p-1.5 rounded-2xl shadow-lg border border-gray-100">
                <div class="pl-3 text-gray-400"><i id="searchIcon" class="fas fa-search"></i></div>
                <input type="text" id="smartInput" oninput="handleSmartInput()" placeholder="搜尋或輸入新產品..." 
                    class="flex-1 p-2.5 bg-transparent border-none focus:ring-0 text-gray-700 font-medium outline-none">
                <button id="actionBtn" onclick="handleAction()" class="p-2.5 px-6 rounded-xl font-bold btn-bounce transition-all text-sm bg-gray-100 text-gray-400">
                    <span id="btnText">搜尋</span>
                </button>
            </div>
        </div>

        <div id="productList" class="px-4 space-y-6 mt-4"></div>

        <div id="emptyState" class="hidden text-center py-20 px-4">
            <div class="bg-gray-200/50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-search text-gray-400 text-2xl"></i>
            </div>
            <p class="text-gray-500 font-medium">無資料</p>
        </div>

        <div class="mt-12 mb-6 text-center">
            <div class="inline-block px-4 py-1.5 bg-gray-200 text-gray-500 text-[10px] font-bold rounded-full tracking-widest uppercase">
                Version 1.3 - 計算機品項優化版
            </div>
            <p class="text-[9px] text-gray-400 mt-2">© 2024 Price Tracker Helper</p>
        </div>
    </main>

    <!-- 購物計算機抽屜 -->
    <div id="calcDrawer" class="fixed inset-x-0 bottom-0 z-[60] bg-white rounded-t-[2.5rem] shadow-[0_-10px_40px_rgba(0,0,0,0.1)] border-t border-gray-100 drawer-hidden h-[85vh] flex flex-col">
        <div class="w-full flex justify-center pt-3 pb-2 cursor-pointer" onclick="toggleCalc()">
            <div class="w-12 h-1.5 bg-gray-200 rounded-full"></div>
        </div>
        
        <div class="px-6 py-2 flex justify-between items-center border-b border-gray-50">
            <h2 class="text-xl font-bold text-gray-800"><i class="fas fa-shopping-cart mr-2 text-orange-500"></i>購物清單</h2>
            <button onclick="clearCalc()" class="text-red-400 text-xs font-bold">清空全部</button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 no-scrollbar">
            <!-- 輸入區域：加入品項名稱欄位 -->
            <div class="bg-orange-50 rounded-2xl p-4 mb-6 space-y-3">
                <div class="grid grid-cols-2 gap-2">
                    <div class="col-span-1">
                        <label class="text-[10px] text-orange-400 font-bold ml-1 uppercase">品項名稱</label>
                        <input type="text" id="calcItemName" placeholder="例如：雞蛋" class="w-full p-3 bg-white rounded-xl border-none outline-none focus:ring-2 focus:ring-orange-300 text-sm">
                    </div>
                    <div class="col-span-1">
                        <label class="text-[10px] text-orange-400 font-bold ml-1 uppercase">金額</label>
                        <input type="number" id="calcAmount" placeholder="0.00" class="w-full p-3 bg-white rounded-xl border-none outline-none focus:ring-2 focus:ring-orange-300 text-sm font-bold">
                    </div>
                </div>
                <button onclick="addToCalc()" class="w-full py-3 bg-orange-500 text-white rounded-xl font-bold shadow-lg shadow-orange-100 btn-bounce text-sm">
                    <i class="fas fa-plus mr-1"></i> 加入清單
                </button>
            </div>

            <div id="calcList" class="space-y-3 mb-8"></div>
        </div>

        <!-- 底部總結 -->
        <div class="p-6 bg-gray-50 border-t border-gray-100 pb-10">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <span class="text-xs font-medium text-gray-500">信用卡優惠/折扣:</span>
                    <select id="calcDiscount" onchange="updateCalcTotal()" class="bg-white border-none rounded-lg text-xs font-bold p-1 px-2 focus:ring-1 focus:ring-orange-300">
                        <option value="1">無折扣</option>
                        <option value="0.95">95 折 (5% Off)</option>
                        <option value="0.9">9 折 (10% Off)</option>
                        <option value="0.85">85 折 (15% Off)</option>
                        <option value="0.8">8 折 (20% Off)</option>
                        <option value="custom">自定義 %</option>
                    </select>
                </div>
                <div id="customDiscountBox" class="hidden">
                    <input type="number" id="customDiscountVal" oninput="updateCalcTotal()" placeholder="92" class="w-12 p-1 text-center bg-white rounded-lg text-xs border-none outline-none focus:ring-1 focus:ring-orange-300"> <span class="text-[10px]">%</span>
                </div>
            </div>

            <div class="space-y-1">
                <div class="flex justify-between text-gray-400 text-[10px]">
                    <span>原始總計</span>
                    <span id="calcSubtotal">$0.00</span>
                </div>
                <div class="flex justify-between items-end">
                    <span class="text-gray-800 font-bold text-sm">折後應付金額</span>
                    <span id="calcFinalTotal" class="text-2xl font-black text-orange-600">$0.00</span>
                </div>
            </div>
            <button onclick="toggleCalc()" class="w-full mt-4 py-3 bg-gray-800 text-white rounded-2xl font-bold btn-bounce">返回追蹤清單</button>
        </div>
    </div>

    <!-- 彈出式編輯視窗 (Modal) -->
    <div id="editModal" class="fixed inset-0 bg-black/60 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-3xl w-full max-w-sm p-6 shadow-2xl">
            <h3 id="modalTitle" class="text-lg font-bold text-gray-800 mb-4">編輯</h3>
            <div id="modalBody" class="space-y-4"></div>
            <div class="flex gap-3 mt-6">
                <button onclick="closeModal()" class="flex-1 py-3 rounded-xl font-bold bg-gray-100 text-gray-500">取消</button>
                <button id="modalConfirmBtn" class="flex-1 py-3 rounded-xl font-bold bg-teal-600 text-white">確認</button>
            </div>
        </div>
    </div>

    <script>
        const APP_VERSION = "V1.3";
        let products = JSON.parse(localStorage.getItem('priceTracker_v8') || '[]');
        let cartItems = [];

        const UNIT_OPTIONS = [
            {v: 'pc', n: '個'}, {v: 'pack', n: '包'}, {v: 'box', n: '盒'},
            {v: 'g', n: 'g'}, {v: 'kg', n: 'kg'}, 
            {v: 'catty', n: '斤'}, {v: 'lb', n: 'lb'},
            {v: 'ml', n: 'ml'}, {v: 'L', n: 'L'}
        ];

        function save() { localStorage.setItem('priceTracker_v8', JSON.stringify(products)); }

        // --- 計算機邏輯 ---
        function toggleCalc() {
            const drawer = document.getElementById('calcDrawer');
            drawer.classList.toggle('drawer-hidden');
            drawer.classList.toggle('drawer-visible');
        }

        function addToCalc() {
            const nameInput = document.getElementById('calcItemName');
            const amountInput = document.getElementById('calcAmount');
            const amount = parseFloat(amountInput.value);
            const name = nameInput.value.trim() || "未命名品項";

            if (!amount || amount <= 0) return;

            cartItems.push({ id: Date.now(), name: name, amount: amount });
            nameInput.value = "";
            amountInput.value = "";
            renderCalc();
        }

        function removeFromCalc(id) {
            cartItems = cartItems.filter(item => item.id !== id);
            renderCalc();
        }

        function clearCalc() {
            if (confirm("清空購物清單？")) { cartItems = []; renderCalc(); }
        }

        function renderCalc() {
            const list = document.getElementById('calcList');
            list.innerHTML = cartItems.map((item, idx) => `
                <div class="flex justify-between items-center bg-white p-3 rounded-xl border border-gray-100 shadow-sm">
                    <div class="flex items-center gap-3">
                        <span class="w-6 h-6 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center text-[10px] font-bold">${idx + 1}</span>
                        <div>
                            <div class="text-[10px] text-gray-400 leading-tight">${item.name}</div>
                            <div class="font-bold text-gray-700">$${item.amount.toFixed(2)}</div>
                        </div>
                    </div>
                    <button onclick="removeFromCalc(${item.id})" class="text-gray-300 hover:text-red-400 p-1"><i class="fas fa-times"></i></button>
                </div>
            `).join('');
            if (cartItems.length === 0) {
                list.innerHTML = `<p class="text-center text-gray-400 py-10 text-xs">購物清單是空的</p>`;
            }
            updateCalcTotal();
        }

        function updateCalcTotal() {
            const subtotal = cartItems.reduce((acc, cur) => acc + cur.amount, 0);
            const discountSelect = document.getElementById('calcDiscount');
            const customBox = document.getElementById('customDiscountBox');
            let multiplier = 1;

            if (discountSelect.value === 'custom') {
                customBox.classList.remove('hidden');
                const customVal = parseFloat(document.getElementById('customDiscountVal').value) || 100;
                multiplier = customVal / 100;
            } else {
                customBox.classList.add('hidden');
                multiplier = parseFloat(discountSelect.value);
            }

            const finalTotal = subtotal * multiplier;
            document.getElementById('calcSubtotal').innerText = `$${subtotal.toFixed(2)}`;
            document.getElementById('calcFinalTotal').innerText = `$${finalTotal.toFixed(2)}`;
        }

        // --- 核心功能 ---
        function calculateStandard(price, qty, unit) {
            let stdPrice = 0, stdUnit = 'pc';
            const p = parseFloat(price) || 0;
            const q = parseFloat(qty) || 1;
            if (['g', 'kg', 'catty', 'lb'].includes(unit)) {
                let totalGrams = (unit === 'kg') ? q * 1000 : (unit === 'catty') ? q * 600 : (unit === 'lb') ? q * 453.59 : q;
                stdPrice = p / totalGrams; stdUnit = 'g';
            } else if (['ml', 'L'].includes(unit)) {
                const totalMl = (unit === 'L') ? q * 1000 : q;
                stdPrice = p / totalMl; stdUnit = 'ml';
            } else { stdPrice = p / q; stdUnit = 'pc'; }
            return { stdPrice, stdUnit };
        }

        function handleSmartInput() {
            const val = document.getElementById('smartInput').value.trim();
            const actionBtn = document.getElementById('actionBtn');
            const btnText = document.getElementById('btnText');
            const searchIcon = document.getElementById('searchIcon');
            const displayCount = renderApp();
            if (val.length > 0) {
                if (displayCount === 0) {
                    actionBtn.className = "p-2.5 px-6 rounded-xl font-bold btn-bounce transition-all text-sm bg-teal-600 text-white";
                    btnText.innerText = "新增"; searchIcon.className = "fas fa-plus text-white";
                } else {
                    actionBtn.className = "p-2.5 px-6 rounded-xl font-bold btn-bounce transition-all text-sm bg-teal-100 text-teal-600";
                    btnText.innerText = "搜尋"; searchIcon.className = "fas fa-search text-teal-600";
                }
            } else {
                actionBtn.className = "p-2.5 px-6 rounded-xl font-bold btn-bounce transition-all text-sm bg-gray-100 text-gray-400";
                btnText.innerText = "搜尋"; searchIcon.className = "fas fa-search text-gray-400";
            }
        }

        function handleAction() {
            const input = document.getElementById('smartInput');
            const val = input.value.trim();
            if (!val) return;
            if (!products.find(p => p.name.toLowerCase() === val.toLowerCase())) {
                products.unshift({ id: Date.now(), name: val, prices: [] });
                save();
            }
            input.value = ""; renderApp(); handleSmartInput();
        }

        function addCase(prodId) {
            const loc = document.getElementById(`new-loc-${prodId}`).value.trim() || '未指定';
            const price = document.getElementById(`new-price-${prodId}`).value;
            const qty = document.getElementById(`new-qty-${prodId}`).value;
            const unit = document.getElementById(`new-unit-${prodId}`).value;
            const note = document.getElementById(`new-note-${prodId}`).value.trim();
            if (!price) return;
            const { stdPrice, stdUnit } = calculateStandard(price, qty, unit);
            const product = products.find(p => p.id === prodId);
            product.prices.unshift({ id: Date.now(), location: loc, price: parseFloat(price), rawQuantity: parseFloat(qty) || 1, rawUnit: unit, note: note, standardPrice: stdPrice, standardUnitLabel: stdUnit, date: new Date().toLocaleDateString() });
            save(); renderApp();
        }

        function renderApp() {
            const list = document.getElementById('productList');
            const search = document.getElementById('smartInput').value.toLowerCase();
            const filtered = products.filter(p => p.name.toLowerCase().includes(search));
            if (filtered.length === 0) {
                list.innerHTML = ""; document.getElementById('emptyState').classList.remove('hidden');
                return 0;
            }
            document.getElementById('emptyState').classList.add('hidden');
            list.innerHTML = filtered.map(p => {
                const lowest = p.prices.length ? Math.min(...p.prices.map(c => c.standardPrice)) : 0;
                const sortedPrices = [...p.prices].sort((a, b) => a.standardPrice - b.standardPrice);
                return `
                <div class="bg-white rounded-[2rem] card-shadow border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 flex justify-between items-center bg-gray-50/50 border-bottom border-gray-50">
                        <div onclick="editProductName(${p.id}, '${p.name}')" class="flex items-center gap-2 cursor-pointer group">
                            <span class="font-bold text-gray-800 group-hover:text-teal-600 transition-colors">${p.name}</span>
                            <i class="fas fa-pen text-[10px] text-gray-300 group-hover:text-teal-400"></i>
                        </div>
                        <button onclick="deleteProduct(${p.id})" class="text-gray-300 hover:text-red-400 p-2"><i class="fas fa-trash-alt text-xs"></i></button>
                    </div>
                    <div class="max-h-64 overflow-y-auto no-scrollbar">
                        <table class="w-full text-xs">
                            <tbody class="divide-y divide-gray-50">
                                ${sortedPrices.map(c => {
                                    const isLowest = c.standardPrice === lowest && p.prices.length > 1;
                                    return `
                                    <tr onclick="openEditCase(${p.id}, ${c.id})" class="hover:bg-teal-50/30 cursor-pointer ${isLowest ? 'price-row-top' : ''}">
                                        <td class="px-6 py-4 font-medium text-gray-600">
                                            <div class="flex items-center">
                                                ${isLowest ? '<i class="fas fa-crown text-orange-400 mr-1.5 scale-75"></i>' : ''}
                                                ${c.location}
                                            </div>
                                            <div class="text-[9px] text-gray-400 font-normal ml-${isLowest ? '4' : '0'}">${c.date}</div>
                                        </td>
                                        <td class="px-2 py-4">
                                            <div class="text-gray-700 font-medium">$${c.price} / ${c.rawQuantity}${UNIT_OPTIONS.find(u => u.v === c.rawUnit)?.n || c.rawUnit}</div>
                                            ${c.note ? `<div class="text-[10px] text-orange-500 mt-0.5"><i class="fas fa-sticky-note mr-1 scale-75"></i>${c.note}</div>` : ''}
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <span class="px-2 py-1 rounded-lg font-bold ${isLowest ? 'bg-orange-100 text-orange-600 ring-1 ring-orange-200' : 'bg-teal-50 text-teal-600'}">
                                                $${c.standardPrice.toFixed(3)}/${c.standardUnitLabel}
                                            </span>
                                        </td>
                                    </tr>`;
                                }).join('')}
                            </tbody>
                        </table>
                    </div>
                    <div class="p-5 bg-white border-t border-gray-100">
                        <div class="grid grid-cols-4 gap-2 mb-2">
                            <input type="text" id="new-loc-${p.id}" placeholder="地點" class="col-span-1 p-2.5 rounded-xl bg-gray-50 text-xs outline-none focus:ring-1 focus:ring-teal-500/20">
                            <input type="number" id="new-price-${p.id}" placeholder="價格" class="col-span-1 p-2.5 rounded-xl bg-gray-50 text-xs outline-none focus:ring-1 focus:ring-teal-500/20">
                            <input type="number" id="new-qty-${p.id}" placeholder="數量" class="col-span-1 p-2.5 rounded-xl bg-gray-50 text-xs outline-none focus:ring-1 focus:ring-teal-500/20">
                            <select id="new-unit-${p.id}" class="col-span-1 p-2.5 rounded-xl bg-gray-50 text-xs outline-none border-none">
                                ${UNIT_OPTIONS.map(o => `<option value="${o.v}">${o.n}</option>`).join('')}
                            </select>
                        </div>
                        <input type="text" id="new-note-${p.id}" placeholder="備註..." class="w-full p-2.5 text-xs rounded-xl bg-gray-50 outline-none mb-3 focus:ring-1 focus:ring-teal-500/20">
                        <button onclick="addCase(${p.id})" class="w-full bg-teal-600 text-white font-bold py-3 rounded-2xl shadow-md btn-bounce text-sm">新增紀錄</button>
                    </div>
                </div>`;
            }).join('');
            return filtered.length;
        }

        function openEditCase(pid, cid) {
            const p = products.find(x => x.id === pid);
            const c = p.prices.find(x => x.id === cid);
            document.getElementById('modalTitle').innerText = "編輯購物紀錄";
            document.getElementById('modalBody').innerHTML = `
                <div class="space-y-4">
                    <input type="text" id="e-loc" value="${c.location}" placeholder="地點" class="w-full p-3 bg-gray-50 rounded-xl outline-none text-sm">
                    <div class="grid grid-cols-2 gap-3">
                        <input type="number" id="e-price" value="${c.price}" placeholder="價格" class="w-full p-3 bg-gray-50 rounded-xl outline-none text-sm font-bold">
                        <input type="number" id="e-qty" value="${c.rawQuantity}" placeholder="數量" class="w-full p-3 bg-gray-50 rounded-xl outline-none text-sm">
                    </div>
                    <select id="e-unit" class="w-full p-3 bg-gray-50 rounded-xl outline-none text-sm">
                        ${UNIT_OPTIONS.map(o => `<option value="${o.v}" ${c.rawUnit === o.v ? 'selected' : ''}>${o.n}</option>`).join('')}
                    </select>
                    <input type="text" id="e-note" value="${c.note || ''}" placeholder="備註" class="w-full p-3 bg-gray-50 rounded-xl outline-none text-sm">
                    <button onclick="deleteCase(${pid}, ${cid})" class="w-full py-2 text-red-400 text-xs font-bold hover:bg-red-50 rounded-lg">刪除紀錄</button>
                </div>`;
            const btn = document.getElementById('modalConfirmBtn');
            btn.onclick = () => {
                c.location = document.getElementById('e-loc').value || '未指定';
                c.price = parseFloat(document.getElementById('e-price').value) || 0;
                c.rawQuantity = parseFloat(document.getElementById('e-qty').value) || 1;
                c.rawUnit = document.getElementById('e-unit').value;
                c.note = document.getElementById('e-note').value.trim();
                const { stdPrice, stdUnit } = calculateStandard(c.price, c.rawQuantity, c.rawUnit);
                c.standardPrice = stdPrice; c.standardUnitLabel = stdUnit;
                save(); renderApp(); closeModal();
            };
            document.getElementById('editModal').classList.replace('hidden', 'flex');
        }

        function editProductName(id, oldName) {
            document.getElementById('modalTitle').innerText = "修改產品名稱";
            document.getElementById('modalBody').innerHTML = `<input type="text" id="editNameInput" value="${oldName}" class="w-full p-3 rounded-xl bg-gray-50 outline-none">`;
            const btn = document.getElementById('modalConfirmBtn');
            btn.onclick = () => {
                const newName = document.getElementById('editNameInput').value.trim();
                if (newName) { products.find(x => x.id === id).name = newName; save(); renderApp(); closeModal(); }
            };
            document.getElementById('editModal').classList.replace('hidden', 'flex');
        }

        function deleteCase(pid, cid) {
            if (confirm("確定要刪除這筆紀錄？")) {
                const p = products.find(x => x.id === pid);
                p.prices = p.prices.filter(x => x.id !== cid);
                save(); renderApp(); closeModal();
            }
        }

        function deleteProduct(id) {
            if (confirm("確定要刪除整項產品及其所有紀錄？")) { products = products.filter(p => p.id !== id); save(); renderApp(); }
        }

        function closeModal() { document.getElementById('editModal').classList.replace('flex', 'hidden'); }

        function exportToExcel() {
            if (products.length === 0) return alert("無資料可匯出");
            const data = products.flatMap(p => p.prices.map(c => ({
                "產品名稱": p.name, "地點": c.location, "價格": c.price, "數量": c.rawQuantity, "單位": c.rawUnit, "備註": c.note || "", "標準單價": c.standardPrice.toFixed(4), "日期": c.date, "App版本": APP_VERSION
            })));
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "PriceData");
            XLSX.writeFile(wb, `價格追蹤_${APP_VERSION}_${new Date().toISOString().split('T')[0]}.xlsx`);
        }

        function importFromExcel(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (evt) => {
                const data = XLSX.utils.sheet_to_json(XLSX.read(evt.target.result, { type: 'binary' }).Sheets[XLSX.read(evt.target.result, { type: 'binary' }).SheetNames[0]]);
                const newProducts = [];
                data.forEach(row => {
                    let p = newProducts.find(x => x.name === row["產品名稱"]);
                    if (!p) { p = { id: Date.now() + Math.random(), name: row["產品名稱"], prices: [] }; newProducts.push(p); }
                    const { stdPrice, stdUnit } = calculateStandard(row["價格"], row["數量"], row["單位"]);
                    p.prices.push({ id: Date.now() + Math.random(), location: row["地點"] || "未指定", price: row["價格"], rawQuantity: row["數量"], rawUnit: row["單位"] || "pc", note: row["備註"] || "", standardPrice: stdPrice, standardUnitLabel: stdUnit, date: row["日期"] || new Date().toLocaleDateString() });
                });
                if (confirm(`匯入 ${newProducts.length} 個產品，將覆蓋現有資料？`)) { products = newProducts; save(); renderApp(); }
            };
            reader.readAsBinaryString(file);
            e.target.value = "";
        }

        window.onload = () => { renderApp(); renderCalc(); };
    </script>
</body>
</html>
